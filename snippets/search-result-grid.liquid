{% unless grid_item_width %}
    {% assign grid_item_width = 'large--one-third medium--one-half' %}
  {% endunless %}
  
  {% unless current_collection %}
    {% assign current_collection = collection %}
  {% endunless %}
  
  {% assign on_sale = false %}
  {% if item.compare_at_price > item.price %}
    {% assign on_sale = true %}
  {% endif %}
  
  {% assign sold_out = true %}
  {% if item.available %}
    {% assign sold_out = false %}
  {% endif %}

  {% comment %} Enhanced pricing calculations for better price display {% endcomment %}
  {% assign lowest_price = item.price %}
  {% assign highest_compare_price = item.compare_at_price %}
  {% assign highest_savings = 0 %}
  {% assign first_price = item.price %}
  {% assign last_price = item.price %}

  {% for variant in item.variants %}
    {% if variant.price < lowest_price %}
      {% assign lowest_price = variant.price %}
    {% endif %}
    {% if variant.price < first_price %}
      {% assign first_price = variant.price %}
    {% endif %}
    {% if variant.price > last_price %}
      {% assign last_price = variant.price %}
    {% endif %}
    {% if variant.compare_at_price > highest_compare_price %}
      {% assign highest_compare_price = variant.compare_at_price %}
    {% endif %}
    {% if variant.compare_at_price > variant.price %}
      {% assign variant_savings = variant.compare_at_price | minus: variant.price %}
      {% if variant_savings > highest_savings %}
        {% assign highest_savings = variant_savings %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% if shop.money_format contains 'money' %}
    {% assign first_price = first_price | money %}
    {% assign last_price = last_price | money %}
  {% else %}
    {% assign first_price = first_price | money_without_trailing_zeros %}
    {% assign last_price = last_price | money_without_trailing_zeros %}
  {% endif %}
  
  {%- assign width = '250' -%}
  {%- assign height = '225' -%}
  
  <div class="grid-item search-result {{ grid_item_width }} mobile-product-grid-item-wrap{% unless section.settings.hide_sold_out_overlay %}{% if sold_out %}{% unless item.tags contains "Rental" %} sold-out{% endunless %}{% endif %}{% endunless %}{% if on_sale %} on-sale{% endif %}">
    <div class="product-grid-item-wrap" {% if section.settings.round_product_borders %}style="border-radius: 5px;"{% endif %}>
      {% if item.tags contains 'Rental' %}
        {% if settings.rental_badge %}
        <div class="rental-badge">
          Rental
        </div>
        {% endif %}
      {% endif %}
    
      <a href="{{ item.url | within: current_collection }}" class="product-grid-item">
      {% if item.object_type == 'product' %}
        {% if item.featured_image %}
        <div class="product-grid-image">
          <div class="product-grid-image--centered">
            {% unless section.settings.hide_sold_out_overlay %}
              {% unless item.tags contains "Rental" %}
                {% if sold_out %}
                  <div class="badge badge--sold-out"><span class="badge-label">{{ 'products.product.sold_out' | t }}</span></div>
                {% endif %}
              {% endunless %}
            {% endunless %}
            {% if item.featured_image %}
              {%- assign image = item.featured_image -%}
              {%- assign max_width = width | plus: 0 -%}
              {%- assign max_height = height | plus: 0 -%}
  
              {%- include 'image-logic' with width: max_width, height: max_height -%}
  
              {%- assign img_url = image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
              <div id="{{ wrapper_id }}" class="lazyload__image-wrapper no-js" style="max-width: {{ max_width }}px">
                <div style="padding-top:{{ 1 | divided_by: image.aspect_ratio | times: 100}}%;">
                  <img class="lazyload no-js"
                    data-src="{{ img_url }}"
                    data-widths="[125, 180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]"
                    data-aspectratio="{{ image.aspect_ratio }}"
                    data-sizes="auto"
                    width="{{ max_width }}"
                    height="{{ max_height }}"
                    alt="{{ image.alt | escape }}">
                </div>
              </div>
              <noscript>
                <img src="{{ image | img_url: '580x' }}"
                  srcset="{{ image | img_url: '580x' }} 1x, {{ image | img_url: '580x', scale: 2 }} 2x"
                  width="580"
                  height="580"
                  alt="{{ image.alt }}" style="opacity:1;">
              </noscript>
            {% else %}
              {% capture current %}{% cycle 1, 2, 3, 4 %}{% endcapture %}
              {% comment %}<div>
              {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
              </div>{% endcomment %}
                <div class="no-product-image-available-search">
                  <p>No Image Available</p>
                </div>
            {% endif %}
          </div>
        </div>
          {% else %}
              {% capture current %}{% cycle 1, 2, 3, 4 %}{% endcapture %}
              {% comment %}<div>
              {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
              </div>{% endcomment %}
              <div class="no-product-image-available-search-box">
                <div class="no-product-image-available-search">
                  <p>No Image Available</p>
                </div>
              </div>
        {% endif %}
       
        {% unless item.vendor == 'Hardware-Catalyst' or item.vendor == "Do It Best" or item.vendor == shop.name %} 
          {% unless settings.hide_brands %}
            <div class="list-view-item__vendor medium-up--hide">{{ item.vendor }}</div>
          {% endunless %}
        {% endunless %}

        <p class="product-description">{{ item.title }}</p>

        {% if section.settings.show_pickup_message %}
        <p class="pickup-message" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}>{{ section.settings.pickup_message }}</p>
        {% endif %}
        {% if section.settings.show_delivery_message %}
        <p class="delivery-message" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}>{{ section.settings.delivery_message }}</p>
        {% endif %}
        {% if section.settings.show_shipping_message %}
        <p class="shipping-message" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}>{{ section.settings.shipping_message }}</p>
        {% endif %}
      
      <!-- Adding messages based on the product tag field -->
        {% if section.settings.enable_tag_message_1 %}
      {% assign tag_condition_1 = section.settings.tag_condition_1 %}
        {% for tag in item.tags %}
          {% if tag == tag_condition_1 %}
               <p class="tag-message" style="color:{{ section.settings.tag_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.tag_message_1 }} </p>
          {% endif %}
        {% endfor %}   
      {% endif %}
      {% if section.settings.enable_tag_message_2 %}
      {% assign tag_condition_2 = section.settings.tag_condition_2 %}
        {% for tag in item.tags %}
          {% if tag == tag_condition_2 %}
               <p class="tag-message" style="color:{{ section.settings.tag_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.tag_message_2 }} </p>
          {% endif %}
        {% endfor %}   
      {% endif %}
      {% if section.settings.enable_tag_message_3 %}
      {% assign tag_condition_3 = section.settings.tag_condition_3 %}
        {% for tag in item.tags %}
          {% if tag == tag_condition_3 %}
               <p class="tag-message" style="color:{{ section.settings.tag_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.tag_message_3 }} </p>
          {% endif %}
        {% endfor %}   
      {% endif %}
      {% if section.settings.enable_tag_message_4 %}
      {% assign tag_condition_4 = section.settings.tag_condition_4 %}
        {% for tag in item.tags %}
          {% if tag == tag_condition_4 %}
               <p class="tag-message" style="color:{{ section.settings.tag_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.tag_message_4 }} </p>
          {% endif %}
        {% endfor %}   
      {% endif %}
      {% if section.settings.enable_tag_message_5 %}
      {% assign tag_condition_5 = section.settings.tag_condition_5 %}
        {% for tag in item.tags %}
          {% if tag == tag_condition_5 %}
               <p class="tag-message" style="color:{{ section.settings.tag_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.tag_message_5 }} </p>
          {% endif %}
        {% endfor %}   
      {% endif %}
      <!-- Adding messages based on the product tag field -->
      
      <!-- Adding messages based on the product type field --> 
        
      {% if section.settings.enable_type_message_1 %}
      {% assign type_condition_1 = section.settings.type_condition_1 %}
          {% if item.type == type_condition_1 %}
               <p class="type-message" style="color:{{ section.settings.type_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.type_message_1 }} </p>
          {% endif %}
      {% endif %} 
        
        {% if section.settings.enable_type_message_2 %}
      {% assign type_condition_2 = section.settings.type_condition_2 %}
          {% if item.type == type_condition_2 %}
               <p class="type-message" style="color:{{ section.settings.type_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.type_message_2 }} </p>
          {% endif %}
      {% endif %} 
        
        {% if section.settings.enable_type_message_3 %}
      {% assign type_condition_3 = section.settings.type_condition_3 %}
          {% if item.type == type_condition_3 %}
               <p class="type-message" style="color:{{ section.settings.type_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.type_message_3 }} </p>
          {% endif %}
      {% endif %} 
        
        {% if section.settings.enable_type_message_4 %}
      {% assign type_condition_4 = section.settings.type_condition_4 %}
          {% if item.type == type_condition_4 %}
               <p class="type-message" style="color:{{ section.settings.type_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.type_message_4 }} </p>
          {% endif %}
      {% endif %}
        
        {% if section.settings.enable_type_message_5 %}
      {% assign type_condition_5 = section.settings.type_condition_5 %}
          {% if item.type == type_condition_5 %}
               <p class="type-message" style="color:{{ section.settings.type_message_color }};{% if section.settings.capitalize_pricing_text %}text-transform: uppercase;{% endif %}"> {{ section.settings.type_message_5 }} </p>
          {% endif %}
      {% endif %}
        
        <!-- Adding messages based on the product type field -->

      {% if section.settings.show_pickup_message %}
      <style>
        .product-item--price {
          margin-top: 15px;
        }
      </style>
      {% endif %}
      
      {% comment %} Enhanced Pricing display logic for search results {% endcomment %}
      {% if settings.display_logged_in_customer_pricing %}
        {% if customer %}
          {% if item.type == 'MAP' or 
                settings.map_brand_1 == item.vendor or 
                settings.map_brand_2 == item.vendor or 
                settings.map_brand_3 == item.vendor or 
                settings.map_brand_4 == item.vendor or 
                settings.map_brand_5 == item.vendor or 
                settings.map_brand_6 == item.vendor or 
                settings.map_brand_7 == item.vendor or 
                settings.map_brand_8 == item.vendor or 
                settings.map_brand_9 == item.vendor or 
                settings.map_brand_10 == item.vendor or 
                settings.map_brand_11 == item.vendor or 
                settings.map_brand_12 == item.vendor or 
                settings.map_brand_13 == item.vendor or 
                settings.map_brand_14 == item.vendor or 
                settings.map_brand_15 == item.vendor or 
                settings.map_brand_16 == item.vendor or 
                settings.map_brand_17 == item.vendor or 
                settings.map_brand_18 == item.vendor or 
                settings.map_brand_19 == item.vendor or 
                settings.map_brand_20 == item.vendor 
          %} 
            {% if settings.map_message != blank %}
              <p class="MAP-Disclaimer" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}><strong><em>{{ settings.map_message }}</em></strong></p>
            {% else %}
              <p class="MAP-Disclaimer" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}><strong><em>Add to cart to see price</em></strong></p>
            {% endif %}
          {% else %}
            {% unless section.settings.hide_price or settings.rental_rates  %}
              {% if item.price > 0 %}
                <div class="product-item--price">     
                  <span class="h2 medium--left">
                    {% if item.price_varies and section.settings.show_price_range %}
                      <span class="product-pricing">
                        {% comment %}
                          Apply <sup> tags to cents if settings.superscript_decimals is enabled
                        {% endcomment %}
                                                 {% if settings.superscript_decimals %}
                           {% if shop.money_format contains '{{amount}}' or shop.money_format contains '{{ amount }}' %}
                             {% assign first_price = first_price | replace: '.', '<sup>' | append: '</sup>' %}
                             {% assign last_price = last_price | replace: '.', '<sup>' | append: '</sup>' %}
                           {% elsif shop.money_format contains '{{amount_with_comma_separator}}' or shop.money_format contains '{{ amount_with_comma_separator }}' %}
                             {% assign first_price = first_price | replace: ',', '<sup>' | append: '</sup>' %}
                             {% assign last_price = last_price | replace: ',', '<sup>' | append: '</sup>' %}
                           {% endif %}
                         {% endif %}
                        {{ first_price }} - {{ last_price }}
                      </span>
                    {% elsif item.price_varies %}
                      <span class="price-varies">{% if section.settings.capitalize_pricing_text %}<span style="text-transform: uppercase;">from</span>{% else %}<small>from</small>{% endif %}</span>
                      {% include 'price' with lowest_price %}
                    {% else %}
                      {% include 'price' with item.price %}
                    {% endif %}
                  </span> 
                  {%- if item.first_available_variant.available and item.first_available_variant.unit_price_measurement -%}
                    {% include 'product-unit-price', variant: item.first_available_variant %}
                  {%- endif -%}
                </div>
              {% endif %}
              {% if on_sale and section.settings.product_savings and highest_savings > 0 %}
                <div class="sale-tag{% if section.settings.product_savings %} medium--right{% endif %}{% if section.settings.product_reviews_enable %} has-reviews{% endif %}">
                  {% if item.variants.size > 1 %}
                    {% if shop.money_format contains 'money' %}
                      {% assign saved_amount = highest_savings | money %}
                    {% else %}
                      {% assign saved_amount = highest_savings | money_without_trailing_zeros %}
                    {% endif %}
                    Save Up To {{ saved_amount }}
                  {% else %}
                    {% assign compare_price = item.compare_at_price %}
                    {% assign product_price = item.price %}
                    {% include 'price-sale' with compare_price: compare_price, product_price: product_price %}
                  {% endif %}
                </div>
              {% endif %}
            {% endunless %}
          {% endif %}
        {% endif %}
      {% else %}
        {% unless section.settings.hide_price or settings.hide_price or settings.rental_rates  %}
          {% if item.type == 'MAP' or 
                settings.map_brand_1 == item.vendor or 
                settings.map_brand_2 == item.vendor or 
                settings.map_brand_3 == item.vendor or 
                settings.map_brand_4 == item.vendor or 
                settings.map_brand_5 == item.vendor or 
                settings.map_brand_6 == item.vendor or 
                settings.map_brand_7 == item.vendor or 
                settings.map_brand_8 == item.vendor or 
                settings.map_brand_9 == item.vendor or 
                settings.map_brand_10 == item.vendor or 
                settings.map_brand_11 == item.vendor or 
                settings.map_brand_12 == item.vendor or 
                settings.map_brand_13 == item.vendor or 
                settings.map_brand_14 == item.vendor or 
                settings.map_brand_15 == item.vendor or 
                settings.map_brand_16 == item.vendor or 
                settings.map_brand_17 == item.vendor or 
                settings.map_brand_18 == item.vendor or 
                settings.map_brand_19 == item.vendor or 
                settings.map_brand_20 == item.vendor 
          %} 
            {% if settings.map_message != blank %}
              <p class="MAP-Disclaimer" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}><strong><em>{{ settings.map_message }}</em></strong></p>
            {% else %}
              <p class="MAP-Disclaimer" {% if section.settings.capitalize_pricing_text %}style="text-transform: uppercase;"{% endif %}><strong><em>Add to cart to see price</em></strong></p>
            {% endif %}
          {% else %}
            {% if item.price > 0 %}
              <div class="product-item--price">     
                <span class="h2 medium--left">
                  {% if item.price_varies and section.settings.show_price_range %}
                    <span class="product-pricing">
                      {% comment %}
                        Apply <sup> tags to cents if settings.superscript_decimals is enabled
                      {% endcomment %}
                                             {% if settings.superscript_decimals %}
                         {% if shop.money_format contains '{{amount}}' or shop.money_format contains '{{ amount }}' %}
                           {% assign first_price = first_price | replace: '.', '<sup>' | append: '</sup>' %}
                           {% assign last_price = last_price | replace: '.', '<sup>' | append: '</sup>' %}
                         {% elsif shop.money_format contains '{{amount_with_comma_separator}}' or shop.money_format contains '{{ amount_with_comma_separator }}' %}
                           {% assign first_price = first_price | replace: ',', '<sup>' | append: '</sup>' %}
                           {% assign last_price = last_price | replace: ',', '<sup>' | append: '</sup>' %}
                         {% endif %}
                       {% endif %}
                      {{ first_price }} - {{ last_price }}
                    </span>
                  {% elsif item.price_varies %}
                    <span class="price-varies">{% if section.settings.capitalize_pricing_text %}<span style="text-transform: uppercase;">from</span>{% else %}<small>from</small>{% endif %}</span>
                    {% include 'price' with lowest_price %}
                  {% else %}
                    {% include 'price' with item.price %}
                  {% endif %}
                </span> 
                {%- if item.first_available_variant.available and item.first_available_variant.unit_price_measurement -%}
                  {% include 'product-unit-price', variant: item.first_available_variant %}
                {%- endif -%}
              </div>
            {% endif %}
            {% if on_sale and section.settings.product_savings and highest_savings > 0 %}
              <div class="sale-tag{% if section.settings.product_savings %} medium--right{% endif %}{% if section.settings.product_reviews_enable %} has-reviews{% endif %}">
                {% if item.variants.size > 1 %}
                  {% if shop.money_format contains 'money' %}
                    {% assign saved_amount = highest_savings | money %}
                  {% else %}
                    {% assign saved_amount = highest_savings | money_without_trailing_zeros %}
                  {% endif %}
                  Save Up To {{ saved_amount }}
                {% else %}
                  {% assign compare_price = item.compare_at_price %}
                  {% assign product_price = item.price %}
                  {% include 'price-sale' with compare_price: compare_price, product_price: product_price %}
                {% endif %}
              </div>
            {% endif %}
          {% endif %}
        {% endunless %}
      {% endif %}

      <div class="product-info-message">     
        <span>
          <span>View More Details</span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" width="16" height="16" style="vertical-align: middle; margin-left: 4px;">
            <path d="M566.6 342.6C579.1 330.1 579.1 309.8 566.6 297.3L406.6 137.3C394.1 124.8 373.8 124.8 361.3 137.3C348.8 149.8 348.8 170.1 361.3 182.6L466.7 288L96 288C78.3 288 64 302.3 64 320C64 337.7 78.3 352 96 352L466.7 352L361.3 457.4C348.8 469.9 348.8 490.2 361.3 502.7C373.8 515.2 394.1 515.2 406.6 502.7L566.6 342.7z"/>
          </svg>
        </span>
      </div>

      {% if section.settings.product_reviews_enable %}
        <span class="shopify-product-reviews-badge" data-id="{{ item.id }}"></span>
      {% endif %}
      
      {% else %}
  
        {% assign img_tag = '<' | append: 'img' %}
        {% if item.content contains img_tag %}
          {% assign src = item.content | split: 'src="' %}
          {% assign src = src[1] | split: '"' | first %}
          {% if src %}
            {% assign image_src = src | replace: '_small.', '.' | replace: '_compact.', '.' | replace: '_medium.', '.' | replace: '_large.', '.' | replace: '_grande.', '.' %}
          {% endif %}
        {% endif %}
  
        {% unless image_src == blank %}
        <div class="product-grid-image">
          <div class="product-grid-image--centered">
            {{ image_src | img_tag }}
          </div>
        </div>
        {% endunless %}
  
        <p class="h6">{{ item.title }}</p>
  
        <div class="rte">
          {% if item.excerpt.size > 0 %}
            <p>{{ item.excerpt | strip_html | truncatewords: 30 }}</p>
          {% else %}
            <p>{{ item.content | strip_html | truncatewords: 30 }}</p>
          {% endif %}
        </div>
      {% endif %}
  
  
      </a> 
    </div>
  </div>